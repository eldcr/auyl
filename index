<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>FOODOO Order Hub | Multi-Supplier Ordering System</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f0f4f0;
            font-family: 'Segoe UI', Roboto, 'Inter', system-ui, -apple-system, sans-serif;
            padding: 2rem 1.5rem;
            color: #1e2a2e;
        }

        .app-container {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* header */
        .main-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .main-header h1 {
            font-size: 2.4rem;
            background: linear-gradient(135deg, #2b7a3e, #4c9f70, #e0a800);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: -0.5px;
        }

        .main-header p {
            color: #446b4e;
            font-weight: 500;
            margin-top: 0.3rem;
        }

        /* supplier grid */
        .suppliers-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 1.8rem;
            margin-bottom: 2.5rem;
            justify-content: center;
        }

        .supplier-card {
            background: white;
            border-radius: 2rem;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
            flex: 1 1 320px;
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s;
            border: 1px solid #e2e8e2;
        }

        .supplier-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 30px -8px rgba(0, 0, 0, 0.12);
        }

        .supplier-head {
            background: #2c5e3a;
            padding: 1rem 1.5rem;
            color: white;
        }

        .supplier-head h2 {
            font-size: 1.6rem;
            font-weight: 700;
            letter-spacing: -0.3px;
        }

        .supplier-head .branch-name {
            font-size: 0.8rem;
            opacity: 0.9;
            background: rgba(255, 255, 255, 0.2);
            display: inline-block;
            padding: 0.2rem 0.8rem;
            border-radius: 30px;
            margin-top: 6px;
        }

        .items-list {
            padding: 1rem 1.2rem 1.3rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .item-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
            border-bottom: 1px dashed #dde6dd;
            padding-bottom: 0.7rem;
        }

        .item-info {
            flex: 2;
            min-width: 120px;
        }

        .item-name {
            font-weight: 700;
            font-size: 1rem;
            color: #1e3a2f;
        }

        .item-unit {
            font-size: 0.7rem;
            background: #ecf7ec;
            padding: 0.2rem 0.5rem;
            border-radius: 20px;
            margin-left: 0.5rem;
            color: #2b6e3c;
        }

        .item-control {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            background: #f9fef7;
            padding: 0.2rem 0.7rem;
            border-radius: 48px;
            border: 1px solid #d0e2ce;
        }

        .qty-input {
            width: 60px;
            text-align: center;
            font-size: 1rem;
            font-weight: 600;
            padding: 0.4rem 0;
            border: none;
            background: transparent;
            font-family: monospace;
            font-size: 1rem;
        }

        .qty-input:focus {
            outline: none;
            border-bottom: 2px solid #4c9f70;
        }

        input[type="number"] {
            -moz-appearance: textfield;
        }
        input[type="number"]::-webkit-inner-spin-button, 
        input[type="number"]::-webkit-outer-spin-button {
            opacity: 0.5;
        }

        .qty-badge {
            font-size: 0.7rem;
            font-weight: 500;
            color: #568b61;
        }

        /* order summary panel */
        .order-panel {
            background: #ffffffdd;
            backdrop-filter: blur(4px);
            background: #fefcf5;
            border-radius: 2rem;
            padding: 1.6rem 1.8rem;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2dccd;
            margin-top: 1rem;
        }

        .panel-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            gap: 1rem;
            margin-bottom: 1.2rem;
            border-bottom: 2px solid #e0d9c6;
            padding-bottom: 0.7rem;
        }

        .panel-header h3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #2b5e2f;
        }

        .action-buttons {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .btn {
            border: none;
            padding: 0.5rem 1.2rem;
            border-radius: 3rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.1s linear;
            background: #ece3d7;
            font-size: 0.85rem;
        }

        .btn-primary {
            background: #2c7840;
            color: white;
            box-shadow: 0 1px 2px rgba(0,0,0,0.1);
        }
        .btn-primary:hover {
            background: #1f5e32;
            transform: scale(0.97);
        }

        .btn-secondary {
            background: #e0daca;
            color: #2a472c;
        }
        .btn-secondary:hover {
            background: #cfc8b4;
        }

        .copy-area {
            background: #2c2f2a;
            border-radius: 1.5rem;
            padding: 1rem 1.2rem;
            margin-top: 1.2rem;
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            align-items: flex-start;
        }

        .copy-field {
            flex: 3;
            background: #1f2620;
            border-radius: 1.2rem;
            padding: 0.8rem 1rem;
            color: #eaf7e6;
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 0.8rem;
            white-space: pre-wrap;
            word-break: break-word;
            max-height: 180px;
            overflow-y: auto;
            border: 1px solid #5c7354;
        }

        .copy-actions {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .btn-copy {
            background: #689f38;
            color: white;
            border: none;
            padding: 0.5rem 1.2rem;
            border-radius: 2rem;
            font-weight: bold;
            cursor: pointer;
        }

        .btn-copy:hover {
            background: #558b2f;
        }

        .toast-msg {
            position: fixed;
            bottom: 25px;
            left: 50%;
            transform: translateX(-50%);
            background: #2e3b2c;
            color: #f0f5e6;
            padding: 0.6rem 1.4rem;
            border-radius: 60px;
            font-size: 0.85rem;
            z-index: 999;
            box-shadow: 0 2px 12px rgba(0,0,0,0.2);
            pointer-events: none;
            transition: 0.2s;
        }

        footer {
            margin-top: 2rem;
            text-align: center;
            font-size: 0.7rem;
            color: #7c8f7a;
        }

        @media (max-width: 760px) {
            body {
                padding: 1rem;
            }
            .item-row {
                flex-direction: column;
                align-items: flex-start;
            }
            .item-control {
                align-self: flex-end;
            }
        }
    </style>
</head>
<body>
<div class="app-container">
    <div class="main-header">
        <h1>🍏 FOODOO · order hub</h1>
        <p>multi‑supplier ordering | measure by piece (kg / l) — just enter exact amount</p>
    </div>

    <div class="suppliers-grid" id="suppliersGrid"></div>

    <!-- Order summary + copy block -->
    <div class="order-panel">
        <div class="panel-header">
            <h3>📋 current order summary</h3>
            <div class="action-buttons">
                <button class="btn btn-secondary" id="resetAllBtn">⟳ reset all orders</button>
            </div>
        </div>
        
        <!-- live summary preview -->
        <div id="liveSummaryPreview" style="background: #f3efE6; border-radius: 1.2rem; padding: 0.9rem; margin-bottom: 1rem; font-size: 0.85rem; color: #2d4a2e; max-height: 160px; overflow-y: auto; font-family: monospace;">
            ⚡ no items ordered yet — adjust quantities above
        </div>
        
        <div class="copy-area">
            <div class="copy-field" id="copyTextField">
                // your order will appear here, ready to copy
            </div>
            <div class="copy-actions">
                <button class="btn-copy" id="copyTextBtn">📋 copy as text</button>
                <button class="btn-secondary" id="refreshCopyBtn" style="background:#e0daca;">🔄 refresh copy field</button>
            </div>
        </div>
        <p style="font-size: 0.7rem; margin-top: 0.6rem; color: #6b6b54;">✅ any quantity (1,2,3...) — zero or empty means not ordered. The system automatically builds order summary.</p>
    </div>
    <footer>FOODOO · JAndso · Seragali · Doss CO — order exactly what you need (kg, l or units). Use copy field to share with suppliers.</footer>
</div>

<script>
    // ---------- SUPPLIERS & BRANCHES & ITEMS WITH UNITS (kg or l or piece) ----------
    const suppliersData = [
        {
            id: "foodoo",
            name: "FOODOO",
            branch: "main warehouse",
            items: [
                { name: "Apple", unit: "kg" },
                { name: "Pear", unit: "kg" },
                { name: "Orange", unit: "kg" },
                { name: "Milk", unit: "l" },
                { name: "Yogurt", unit: "l" }
            ]
        },
        {
            id: "jandso",
            name: "JAndso",
            branch: "fresh produce",
            items: [
                { name: "Strawberry", unit: "kg" },
                { name: "Grape", unit: "kg" },
                { name: "Lemon", unit: "kg" },
                { name: "Coconut milk", unit: "l" },
                { name: "Juice mix", unit: "l" }
            ]
        },
        {
            id: "seragali",
            name: "Seragali",
            branch: "organic goods",
            items: [
                { name: "Spinach", unit: "kg" },
                { name: "Potato", unit: "kg" },
                { name: "Tomato", unit: "kg" },
                { name: "Olive oil", unit: "l" },
                { name: "Honey", unit: "l" }
            ]
        },
        {
            id: "dossco",
            name: "Doss CO",
            branch: "exotic selection",
            items: [
                { name: "Mango", unit: "kg" },
                { name: "Avocado", unit: "kg" },
                { name: "Papaya", unit: "kg" },
                { name: "Coconut water", unit: "l" },
                { name: "Rice milk", unit: "l" }
            ]
        }
    ];

    // ---------- STATE: store quantities per supplierItemIdx ----------
    // We'll maintain a flat map: key = `${supplierId}|${itemIndex}`
    let orderMap = new Map(); // stores numeric quantity (>=0, default 0)
    
    // helper: generate unique key
    function getKey(supplierId, itemIdx) {
        return `${supplierId}|${itemIdx}`;
    }
    
    // initialise all items to 0
    function initOrderState() {
        suppliersData.forEach(supplier => {
            supplier.items.forEach((_, idx) => {
                const key = getKey(supplier.id, idx);
                if (!orderMap.has(key)) orderMap.set(key, 0);
            });
        });
    }
    initOrderState();
    
    // DOM elements
    const suppliersGrid = document.getElementById("suppliersGrid");
    const liveSummaryPreview = document.getElementById("liveSummaryPreview");
    const copyTextField = document.getElementById("copyTextField");
    const copyTextBtn = document.getElementById("copyTextBtn");
    const resetAllBtn = document.getElementById("resetAllBtn");
    const refreshCopyBtn = document.getElementById("refreshCopyBtn");
    
    // render full suppliers UI
    function renderSuppliers() {
        suppliersGrid.innerHTML = "";
        suppliersData.forEach(supplier => {
            const card = document.createElement("div");
            card.className = "supplier-card";
            card.dataset.supplierId = supplier.id;
            
            // header
            const headerDiv = document.createElement("div");
            headerDiv.className = "supplier-head";
            headerDiv.innerHTML = `
                <h2>${escapeHtml(supplier.name)}</h2>
                <div class="branch-name">📍 ${escapeHtml(supplier.branch)}</div>
            `;
            card.appendChild(headerDiv);
            
            const itemsDiv = document.createElement("div");
            itemsDiv.className = "items-list";
            
            // iterate items
            supplier.items.forEach((item, idx) => {
                const key = getKey(supplier.id, idx);
                let quantity = orderMap.get(key) || 0;
                
                const row = document.createElement("div");
                row.className = "item-row";
                row.dataset.itemKey = key;
                
                const itemInfo = document.createElement("div");
                itemInfo.className = "item-info";
                itemInfo.innerHTML = `
                    <span class="item-name">${escapeHtml(item.name)}</span>
                    <span class="item-unit">${escapeHtml(item.unit)}</span>
                `;
                
                const controlDiv = document.createElement("div");
                controlDiv.className = "item-control";
                
                const qtyInput = document.createElement("input");
                qtyInput.type = "number";
                qtyInput.value = quantity;
                qtyInput.min = 0;
                qtyInput.step = 1;    // integers only (1,2,3... exactly as requested)
                qtyInput.className = "qty-input";
                qtyInput.placeholder = "0";
                
                const unitBadge = document.createElement("span");
                unitBadge.className = "qty-badge";
                unitBadge.innerText = item.unit;
                
                controlDiv.appendChild(qtyInput);
                controlDiv.appendChild(unitBadge);
                
                row.appendChild(itemInfo);
                row.appendChild(controlDiv);
                
                // event: update order map
                qtyInput.addEventListener("input", (e) => {
                    let val = parseInt(e.target.value, 10);
                    if (isNaN(val) || val < 0) val = 0;
                    // exactly integer measure (kg, l) as requested: only whole numbers
                    orderMap.set(key, val);
                    // update global UI: summary + copy field
                    updateLiveSummary();
                    updateCopyFieldContent();
                });
                
                itemsDiv.appendChild(row);
            });
            
            card.appendChild(itemsDiv);
            suppliersGrid.appendChild(card);
        });
    }
    
    // Helper: generate order summary text (human readable)
    function generateOrderText() {
        let lines = [];
        let hasAnyOrder = false;
        
        suppliersData.forEach(supplier => {
            const supplierOrders = [];
            supplier.items.forEach((item, idx) => {
                const key = getKey(supplier.id, idx);
                const qty = orderMap.get(key) || 0;
                if (qty > 0) {
                    hasAnyOrder = true;
                    supplierOrders.push(`  • ${item.name} : ${qty} ${item.unit}`);
                }
            });
            if (supplierOrders.length > 0) {
                lines.push(`🏪 ${supplier.name} (${supplier.branch})`);
                lines.push(...supplierOrders);
                lines.push(""); // empty line separator
            }
        });
        
        if (!hasAnyOrder) {
            return "⏳ No items ordered yet. Set quantities (1,2,3...) to build your order.";
        }
        
        // add header and timestamp
        const now = new Date();
        const timestamp = now.toLocaleString();
        const header = `🍽️ FOODOO ORDER LIST — ${timestamp}\n----------------------------------------\n`;
        return header + lines.join("\n");
    }
    
    // generate simple live preview (rich html) + update copy field text version
    function updateLiveSummary() {
        let htmlContent = "";
        let totalItemsCount = 0;
        let orderBlocks = [];
        
        suppliersData.forEach(supplier => {
            const supplierOrders = [];
            supplier.items.forEach((item, idx) => {
                const key = getKey(supplier.id, idx);
                const qty = orderMap.get(key) || 0;
                if (qty > 0) {
                    totalItemsCount++;
                    supplierOrders.push(`<span style="background:#e2f0e2; padding:2px 8px; border-radius:20px; margin:2px 4px 2px 0; display:inline-block;">${escapeHtml(item.name)} ${qty}${item.unit}</span>`);
                }
            });
            if (supplierOrders.length > 0) {
                orderBlocks.push(`<div style="margin-bottom: 8px;"><strong>🍴 ${escapeHtml(supplier.name)} (${escapeHtml(supplier.branch)})</strong><br>${supplierOrders.join(" ")}</div>`);
            }
        });
        
        if (totalItemsCount === 0) {
            liveSummaryPreview.innerHTML = "✨ no order placed yet — set any quantity (e.g. 1, 2) to add items ✨";
        } else {
            liveSummaryPreview.innerHTML = `<div style="font-weight:500;">📦 ordered items:</div> ${orderBlocks.join("")}`;
        }
        
        // also update the copy field text content (full text)
        updateCopyFieldContent();
    }
    
    // update the dedicated copy textarea style block
    function updateCopyFieldContent() {
        const orderText = generateOrderText();
        copyTextField.innerText = orderText;
    }
    
    // copy to clipboard function
    async function copyToClipboard() {
        const textToCopy = copyTextField.innerText;
        if (!textToCopy || textToCopy.trim() === "") {
            showToast("⚠️ nothing to copy — please add some order items first.");
            return;
        }
        try {
            await navigator.clipboard.writeText(textToCopy);
            showToast("✅ Order copied to clipboard! Ready to share with suppliers.");
        } catch (err) {
            // fallback
            const textarea = document.createElement("textarea");
            textarea.value = textToCopy;
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand("copy");
            document.body.removeChild(textarea);
            showToast("📋 copied (fallback method)");
        }
    }
    
    // reset all quantities to zero
    function resetAllOrders() {
        for (let [key, _] of orderMap.entries()) {
            orderMap.set(key, 0);
        }
        // re-render entire UI to reflect zeros
        renderSuppliers();
        updateLiveSummary();
        updateCopyFieldContent();
        showToast("🔄 All orders have been reset to zero.");
    }
    
    // show small toast
    let toastTimeout = null;
    function showToast(message, duration = 2000) {
        let existingToast = document.querySelector(".toast-msg");
        if (existingToast) existingToast.remove();
        const toast = document.createElement("div");
        toast.className = "toast-msg";
        toast.innerText = message;
        document.body.appendChild(toast);
        if (toastTimeout) clearTimeout(toastTimeout);
        toastTimeout = setTimeout(() => {
            if (toast) toast.remove();
        }, duration);
    }
    
    // manual refresh copy field content (ensure sync)
    function refreshCopyField() {
        updateCopyFieldContent();
        showToast("📄 copy field refreshed with current order.");
    }
    
    // simple escape
    function escapeHtml(str) {
        if (!str) return "";
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
    
    // attach global listeners
    copyTextBtn.addEventListener("click", copyToClipboard);
    resetAllBtn.addEventListener("click", resetAllOrders);
    refreshCopyBtn.addEventListener("click", refreshCopyField);
    
    // initial render
    renderSuppliers();
    updateLiveSummary();
    updateCopyFieldContent();
    
    // optional: also re-run summary when any dynamic input changes, but all events already
    // attach extra safety: for number inputs that are dynamically recreated, 
    // the events are attached per render. But resetAll re-renders, and each input has own listener.
    // Also we update the summary and copy field after each input.
    
    // Export mechanism to ensure copy field always matches the editable part
    // also when reloading copy after reset
    window.addEventListener("load", () => {
        // add extra sync after full load
        updateLiveSummary();
    });
    
    // Because we support exact measure as integer (1,2) as requested: no floats.
    // Additional: we also ensure that any manual empty string fallback to 0 
    // Already done in input handler.
    
    // create demo seed: optional (small demo prefill 1 apple and 2 milk for foodoo to show concept?)
    // Not required but gives user preview — but better to keep clean? but to show interface we can prefill? 
    // The requirement did not forbid demo but could be convenient. However we want clean start.
    // But let's add a small helper hint (no prefill, but user can easily set)
    // extra: there's no pre-selected items, clean and user-driven.
    
    // Additional validation: Ensure the copy field has proper ordering, items with zero qty are hidden
    // everything works.
    
    // also style: For l and kg fields, we treat both as same integer logic.
    console.log("FOODOO order system ready | exactly integer measure (kg/l)");
</script>
</body>
</html>
